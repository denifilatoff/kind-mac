# ─── kind cluster — reusable configuration ────────────────────────────────────
# Edit this file to customise your local cluster.
#
#   ./setup.sh             — create or upgrade cluster
#   ./setup.sh --recreate  — delete + recreate (keeps host storage)
#
# Copy this file to .env and adjust values for your environment:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Cluster ───────────────────────────────────────────────────────────────────
CLUSTER_NAME="local-dev"
K8S_VERSION="v1.35.0"      # Browse tags: https://hub.docker.com/r/kindest/node/tags
SINGLE_NODE=false          # true → control-plane only (no workers); false → 1 control-plane + 2 workers

# ── Optional feature toggles ──────────────────────────────────────────────────
# Set to "false" to skip the corresponding block. Persistent storage and the
# kind cluster itself are always created.
ENABLE_INGRESS=true   # cert-manager + Gateway API + Istio + IngressClass + wildcard TLS + ServiceMonitor CRD + DNS check
ENABLE_REGISTRY=true  # local kind-registry container + KEP-1755 ConfigMap + Docker Hub mirrors + containerd no-proxy

# ── Host ports ────────────────────────────────────────────────────────────────
# A single Istio gateway (gateway-istio in istio-system) handles HTTPRoute,
# classic Ingress (ingressClassName: istio), and Istio Gateway+VirtualService.
# Change these if the defaults conflict with something already running on your Mac.
ISTIO_HTTP_PORT=80          # Istio gateway — HTTP  (host side)
ISTIO_HTTPS_PORT=443        # Istio gateway — HTTPS (host side)
ISTIO_NODEPORT_HTTP=30080   # Istio NodePort inside cluster (must match kind extraPortMappings)
ISTIO_NODEPORT_HTTPS=30443  # Istio NodePort inside cluster (must match kind extraPortMappings)

# ── Local Docker registry ─────────────────────────────────────────────────────
LOCAL_REGISTRY_NAME="kind-registry"
LOCAL_REGISTRY_PORT=5001    # push: localhost:5001/<img>  pull in pods: localhost:5001/<img>

# ── Component versions ────────────────────────────────────────────────────────
ISTIO_VERSION="1.23.3"
CERT_MANAGER_VERSION="v1.16.2"

# ── Persistent storage root ───────────────────────────────────────────────────
# Bind-mounted into every kind node. On macOS /var → /private/var which
# Docker Desktop shares by default — so this path works as-is.
# One-time setup: sudo mkdir -p /var/local-path-provisioner && sudo chmod 777 /var/local-path-provisioner
STORAGE_ROOT="/var/local-path-provisioner"

# ── Docker Hub pull-through mirrors (applied to all kind nodes) ───────────────
# Remove entries that are slow/unreachable from your location.
MIRRORS=(
  "https://dockerhub.timeweb.cloud"
  "https://dockerhub1.beget.com"
  "https://mirror.gcr.io"
)
